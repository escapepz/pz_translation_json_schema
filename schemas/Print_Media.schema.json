{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Print_Media.json Schema",
    "description": "Print media with Print_Media_{MediaName}_{property} pattern",
    "type": "object",
    "patternProperties": {
        "^[A-Za-z0-9_]+$": {
            "type": "string",
            "description": "Pattern: Print_Media_{MediaName}_{property} or other print media keys\n(e.g., Print_Media_KnoxKnews_July1_title, maptext)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}