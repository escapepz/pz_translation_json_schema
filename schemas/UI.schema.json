{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "UI.json Schema",
    "description": "UI elements with UI_{context}_{keyname} pattern",
    "type": "object",
    "patternProperties": {
        "^UI_[a-z_]+$": {
            "type": "string",
            "description": "Pattern: UI_{context}_{keyname} (e.g., UI_mainscreen_survival, UI_optionscreen_fullscreen)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}