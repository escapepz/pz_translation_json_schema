{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Challenge.json Schema",
    "description": "Challenge scenarios with Challenge_{ScenarioId}_{property} pattern",
    "type": "object",
    "patternProperties": {
        "^Challenge_[A-Za-z0-9\\s]+_[a-z]+$": {
            "type": "string",
            "description": "Pattern: Challenge_{ScenarioId}_{property} (e.g., Challenge_YouHaveOneDay_name, Challenge_Opening Hours_desc)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}