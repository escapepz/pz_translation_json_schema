{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Recipes.json Schema",
    "description": "Recipe names in PascalCase",
    "type": "object",
    "patternProperties": {
        "^[A-Z][a-zA-Z0-9]*$": {
            "type": "string",
            "description": "Pattern: {RecipeNameInPascalCase} (e.g., MakeBiscuits, AttachBreadKnifeToSpear)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}