{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Print_Media.json Schema",
    "description": "Print media with Print_Media_{MediaName}_{property} pattern",
    "type": "object",
    "patternProperties": {
        "^Print_Media_[A-Za-z0-9_]+$": {
            "type": "string",
            "description": "Pattern: Print_Media_{MediaName}_{property} (e.g., Print_Media_KnoxKnews_July1_title)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}