{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Sandbox.json Schema",
    "description": "Sandbox options with Sandbox_{OptionName} pattern",
    "type": "object",
    "patternProperties": {
        "^Sandbox_[A-Za-z]+$": {
            "type": "string",
            "description": "Pattern: Sandbox_{OptionName} (e.g., Sandbox_PopulationOptions, Sandbox_ZombieCount)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}