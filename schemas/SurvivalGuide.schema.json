{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "SurvivalGuide.json Schema",
    "description": "Survival guide with SurvivalGuide_entrie{num}{property} pattern",
    "type": "object",
    "patternProperties": {
        "^SurvivalGuide_entrie[0-9]+[a-z]+$": {
            "type": "string",
            "description": "Pattern: SurvivalGuide_{entryNum}{property} (e.g., SurvivalGuide_entrie1title, SurvivalGuide_entrie2txt)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}