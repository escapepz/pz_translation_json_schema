{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MultiStageBuild.json Schema",
    "description": "Multi-stage building recipes with MultiStageBuild_{Type}_{Action} pattern",
    "type": "object",
    "patternProperties": {
        "^MultiStageBuild_[A-Za-z0-9_]+_[0-9]+$": {
            "type": "string",
            "description": "Pattern: MultiStageBuild_{Type}_{Action} (e.g., MultiStageBuild_CreateWoodenWall_1)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}