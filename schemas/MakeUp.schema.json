{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MakeUp.json Schema",
    "description": "MakeUp categories/types with MakeUp(Category|Type)_{Name} pattern",
    "type": "object",
    "patternProperties": {
        "^MakeUp(Category|Type)_[A-Za-z]+$": {
            "type": "string",
            "description": "Pattern: MakeUpCategory/Type_{Name} (e.g., MakeUpCategory_Eyes, MakeUpType_EyesFootball)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}