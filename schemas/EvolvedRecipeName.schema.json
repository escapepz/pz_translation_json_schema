{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "EvolvedRecipeName.json Schema",
    "description": "Evolved recipe items with {ModuleName}.{ItemCodeName} format",
    "type": "object",
    "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z0-9_]+$": {
            "type": "string",
            "description": "Pattern: Base.{ItemCodeName}\n(e.g., Base.CannedBologneseOpen, Base.Teabag2)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}
