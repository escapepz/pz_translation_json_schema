{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "UI.json Schema",
    "description": "UI elements with UI_{context}_{keyname} pattern",
    "type": "object",
    "patternProperties": {
        "^[A-Za-z0-9_\\s/\\(\\)\\-]+$": {
            "type": "string",
            "description": "Pattern: UI_{Key} or non-prefixed keys\n(e.g., UI_mainscreen_survival, UI_optionscreen_binding_Attack/Click)"
        },
        "^\\$": {
            "type": "string"
        }
    },
    "additionalProperties": false
}